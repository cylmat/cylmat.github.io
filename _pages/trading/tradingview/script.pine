var box c = na
if barstate.islast
    if na(c) // first call
        c := box.new(
            left=time,
            top=open,
            right=time + ONE_DAY_MS,
            bottom=close,
            xloc=xloc.bar_time
        )
    else
        box.set_lefttop(c, time, open)
        box.set_rightbottom(c, time + ONE_DAY_MS, close)

