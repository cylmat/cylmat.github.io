// Global scope ! //

// === CHAQUE PLOTS label
plotshape(close > open, text="+", location=location.abovebar)
plotshape(close < open, text="-", location=location.belowbar)
//plotshape(buyCondition, location=location.belowbar, color=color.green)

// === REMPLISSAGE 
// Plots invisibles pour le fill
p_mma_far       = plot(mma90, display=display.none)
p_mma_near      = plot(mma20, display=display.none)
color_mma_over  = mmaOverCondition ? color.new(color.orange, 80) : na
color_mma_under = mmaUnderCondition ? color.new(color.blue, 80) : na

