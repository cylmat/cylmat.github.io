// TIPS //
//var x = 0, Initialized once (on the first bar only)
//Then keeps its value across all bars -> persistent variable
//x = 0, Re-initialized on every bar -> Value is reset each time
//

// === Constantes ===
INDICATOR_NAME="MMA 20/90 Cross with SL/TP"
BUY_ACTION='BUY'
SELL_ACTION='SELL'
TOKEN_API='b7f3c9e1a4d8f62c9e1b7a3d4c5f8e2a'
ONE_DAY_MS=60*60*24*1000

indicator(INDICATOR_NAME, overlay=true)

// === INPUTS ===
i_ema_length = 50 //input.int(50, "EMA Trend")
i_rr         = 2 //input.float(2.0, "Risk Reward", step=0.1)
i_show_boxes = true //input.bool(true, "Afficher FVG")



// ======================== //
// ======================== //
//       Paramètres         //
// ======================== //
// ======================== //

// === MMA ===
mma20     = ta.sma(close, 20)
mma90     = ta.sma(close, 90)

// === EMA TREND ===
ema = ta.ema(close, i_ema_length)

// === other ===
symbol    = syminfo.ticker
timeframe = timeframe.main_period



// ======================== //
// ======================== //
//     Business Rules       //
// ======================== //
// ======================== //



bull_trend = close > ema
bear_trend = close < ema

// === FVG DETECTION ===
bull_fvg = low[1] > high[2] and bull_trend
bear_fvg = high[1] < low[2] and bear_trend


// === BOUGIE ===
body = math.abs(close - open)
upper_wick = high - math.max(open, close)
lower_wick = math.min(open, close) - low


// === Croisement MMA
mmaCrossOver      = ta.crossover(mma20, mma90) 
mmaCrossUnder     = ta.crossunder(mma20, mma90)
mmaOverCondition  = mma20 > mma90
mmaUnderCondition = mma20 < mma90

buyCondition = close > 1.08
//if close > ta.sma(close, 20)




